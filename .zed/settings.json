{
  "agent": {
    "tool_permissions": {
      "default": "confirm",
      "tools": {
        "terminal": {
          "default": "confirm",
          "always_deny": [
            {
              "pattern": "rm\\s+-rf\\s+(/|~)"
            },
            {
              "pattern": "(^|\\s)(cat|sed|grep|rg)\\s+.*\\.(env|pem|key)(\\s|$)"
            },
            {
              "pattern": "supabase\\s+.*service_role"
            }
          ],
          "always_confirm": [
            {
              "pattern": "sudo\\s"
            },
            {
              "pattern": "(npm|pnpm|yarn|bun)\\s+(install|add|dlx|exec|x)\\b"
            },
            {
              "pattern": "gh\\s+(auth|api|repo|release|pr|issue)\\b"
            },
            {
              "pattern": "vercel\\s+(deploy|pull|env)"
            },
            {
              "pattern": "supabase\\s+(db|migration|functions)"
            }
          ]
        },
        "edit_file": {
          "always_deny": [
            {
              "pattern": "\\.env"
            },
            {
              "pattern": "\\.(pem|key|p12|pfx)$"
            },
            {
              "pattern": "SUPABASE_SERVICE_ROLE_KEY"
            }
          ]
        }
      }
    }
  }
}